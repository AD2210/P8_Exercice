{% extends 'base.html.twig' %}

{% block title %}Véhicloc{% endblock %}
{% block header %}
<div class="flex-header">
    <div>
        <h1>Location de voitures à Saint-Étienne</h1>
        <p>Un service de location de voitures au mois pour répondre à vos besoins de mobilité.</p>
    </div>
    <div>
        <img src="{{asset ('/img/car.png') }}" alt="photo d'une voiture">
    </div>
</div>
{% endblock %}

{% block body %}
<section id="fleet">
    <h2>Découvrez la flotte de véhicules chez Véhicloc</h2>
    <p>Que vous ayez besoin d'une petite citadine agile, d'une berline élégante ou même d'un SUV spacieux, nous avons une variété de véhicules  pour répondre à vos exigences.</p>
    <div class="fleet-list">
        {% for voiture in voitures %}
            <article>
            <div class="mini-car-title">
                <a href="{{ path('car', {id: voiture.id})}}">
                    <h3>{{voiture.name }}</h3>
                    <p>ou similaire | Saint-Étienne</p>
                </a>
                <div>
                    <a href="{{ path('car_remove', {id: voiture.id})}}"><img src="{{asset ('/icons/trash.png') }}" alt="icon supprimer" /></a>
                </div>
            </div>
            <div class="mini-car-icons">
                <div>
                    <img src="{{asset ('/icons/persons.png') }}" alt="icon 4 places" />
                    <p>{{voiture.seats}} places</p>
                </div>
                <div>
                    <img src="{{asset ('/icons/motor.png') }}" alt="icon boite de vitesse manuelle" />
                    <p>{% if voiture.gearboxType %}
                        Manuelle
                    {% else %}
                        Automatique
                    {% endif %}
                    </p>
                </div>
                <div>
                    <img src="{{asset ('/icons/km.png') }}" alt="icon km illimités" />
                    <p>Km illimités</p>
                </div>
                <div>
                    <img src="{{asset ('/icons/plus.png') }}" alt="icon plus" />
                    <p>Plus</p>
                </div>
            </div>
            <div class="mini-car-price">
                <p class="price-per-day">{{voiture.daillyPrice | number_format(2,',', ' ')}} € / jour</p>
                <p class="price-per-month">{{voiture.monthlyPrice | number_format(2,',', ' ')}} € / mois</p>
            </div>
        </article>
        {% endfor %}       
    </div>
</section>

<section id="promises">
    <div>
        <h2>La promesse Véhicloc</h2>
        <div class="promise">
            <img src="{{asset ('/icons/insurance.png') }}" alt="icon assurance et Assistance">
            <div class="promise-text">
                <h3>Assurance et Assistance</h3>
                <p>Votre tranquillité d'esprit est notre priorité. Toutes nos locations mensuelles incluent une assurance complète et une assistance routière, pour garantir une conduite en toute sécurité.</p>
            </div>
        </div>
        <div class="promise">
            <img src="{{asset ('/icons/booking.png') }}" alt="icon réservation facile">
            <div class="promise-text">
                <h3>Réservation facile</h3>
                <p>Notre plateforme vous permet de réserver votre voiture en quelques clics. Sélectionnez vos dates, choisissez le modèle qui vous convient et finalisez votre réservation en un rien de temps.</p>
            </div>
        </div>
    </div>
    <div>
        <img src="{{asset ('/img/promise.png') }}" alt="photo d'un route vue du ciel">
    </div>
</section>
{% endblock %}
