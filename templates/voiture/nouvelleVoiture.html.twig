{% extends 'base.html.twig' %}

{% block title %}Véhicloc{% endblock %}

{% block body %}
<section id="add">
    <a href="{{ path('home') }}">← Retour</a>
    <h1>Ajouter une voiture</h1>
    {{ form_start(form) }}
        <div class="input">
            {{ form_row(form.name) }}
        </div>
        <div class="input">
            {{ form_row(form.description) }}
        </div>
        <div class="flex-input">
            <div class="input">
                {{ form_row(form.monthly_price) }}
            </div>
            <div class="input">
                {{ form_row(form.dailly_price) }}
            </div>
        </div>
        <div class="flex-input">
            <div class="input">
                {{ form_row(form.seats) }}
            </div>
            <div class="input">
                {{ form_row(form.gearbox_type) }}
            </div>
        </div>
        <button class="btn-add">Ajouter</button>
    {{ form_end(form) }}
</section>



{% endblock %}